generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String     @id
  email          String     @unique
  name           String
  role           String     @default("driver")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  sponsorId      Int?
  adminId        Int?
  adminProfile   Admin?
  auditLogs      AuditLog[]
  driverProfile  Driver?
  sponsorProfile Sponsor?
}

model Driver {
  id           Int                 @id @default(autoincrement())
  userId       String              @unique
  sponsorId    Int
  points       Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  sponsor      Sponsor             @relation(fields: [sponsorId], references: [id])
  user         User                @relation(fields: [userId], references: [id])
  applications DriverApplication[]
  pointLogs    PointLog[]
  purchases    Purchase[]
}

model Sponsor {
  id                Int                 @id @default(autoincrement())
  userId            String              @unique
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  drivers           Driver[]
  DriverApplication DriverApplication[]
  pointLogs         PointLog[]
  productCatalogs   ProductCatalog[]
  purchases         Purchase[]
  user              User                @relation(fields: [userId], references: [id])
  config            SponsorConfig?
}

model Admin {
  id        Int      @id @default(autoincrement())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model ProductCatalog {
  id           Int        @id @default(autoincrement())
  sponsorId    Int
  productId    String
  name         String
  description  String?
  price        Float
  availability Boolean
  imageUrl     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  category     String
  sponsor      Sponsor    @relation(fields: [sponsorId], references: [id])
  Purchase     Purchase[]
}

model Purchase {
  id         Int            @id @default(autoincrement())
  driverId   Int
  productId  Int
  pointsUsed Int
  status     String         @default("pending")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  sponsorId  Int?
  driver     Driver         @relation(fields: [driverId], references: [id])
  product    ProductCatalog @relation(fields: [productId], references: [id])
  Sponsor    Sponsor?       @relation(fields: [sponsorId], references: [id])
}

model PointLog {
  id            Int      @id @default(autoincrement())
  driverId      Int
  sponsorId     Int
  pointsChanged Int
  reason        String
  createdAt     DateTime @default(now())
  driver        Driver   @relation(fields: [driverId], references: [id])
  sponsor       Sponsor  @relation(fields: [sponsorId], references: [id])
}

model DriverApplication {
  id        Int      @id @default(autoincrement())
  driverId  Int
  sponsorId Int
  status    String   @default("pending")
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  driver    Driver   @relation(fields: [driverId], references: [id])
  sponsor   Sponsor  @relation(fields: [sponsorId], references: [id])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     String
  actionType String
  details    String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model SponsorConfig {
  id         Int      @id @default(autoincrement())
  sponsorId  Int      @unique
  pointValue Float    @default(0.01)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sponsor    Sponsor  @relation(fields: [sponsorId], references: [id])
}

model About {
  id           Int    @id @default(autoincrement())
  sprintNumber Int
  teamNumber   Int
  teamName     String
  chosenTech   String
}

enum PurchaseStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}
