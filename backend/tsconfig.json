{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node", "bcrypt", "aws-lambda", "lodash"]
  },
  "include": ["**/*"],
  "exclude": ["node_modules"]
}